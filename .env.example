# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# vibe_flow_ppt 환경변수 설정 예시
# 이 파일을 .env 로 복사 후 값을 입력하세요
# cp .env.example .env
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── LLM API 키 (사용하는 프로바이더만 입력) ──────────────
# Claude (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
OPENAI_API_KEY=sk-...

# Ollama는 키 불필요 (로컬에서 실행)
# 기본 URL: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# ── 기본 프로바이더 ────────────────────────────────────
# 선택지: ollama/llama3.2 | claude-sonnet-4-5 | gpt-4o
DEFAULT_PROVIDER=ollama/llama3.2

# ── 출력 디렉토리 ──────────────────────────────────────
OUTPUT_DIR=./output

# ── 서버 설정 ──────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Redis (잡 큐) ───────────────────────────────────────────────
# Redis 연결 URL (localhost 대신 127.0.0.1 사용 - Windows IPv6 해석 문제 방지)
REDIS_URL=redis://127.0.0.1:6379

# ── Marp 워커 포트 ──────────────────────────────────────────────
MARP_SERVER_PORT=37717       # FastAPI용
MARP_WORKER_PORT=37718       # ARQ 워커용
